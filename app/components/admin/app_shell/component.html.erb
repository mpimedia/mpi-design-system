<div style="<%= shell_styles %>" role="document">
  <%= render Admin::NavBar::Component.new(**nav_bar_options) %>

  <% if breadcrumb? %>
    <div style="padding: 0 24px; background: #F5F7FA;">
      <%= breadcrumb %>
    </div>
  <% end %>

  <div style="<%= content_wrapper_styles %>">
    <% if show_sidebar? %>
      <aside style="<%= sidebar_styles %>" role="complementary" aria-label="Content sidebar">
        <%= sidebar %>
      </aside>
    <% end %>

    <main style="<%= content_area_styles %>" role="main">
      <%= body %>
    </main>
  </div>
</div>
