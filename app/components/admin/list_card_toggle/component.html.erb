<div class="d-flex align-items-center justify-content-between">
  <div style="<%= result_count_styles %>">
    <%= highlighted_result_text %>
  </div>
  <div class="d-flex align-items-center gap-2">
    <div style="<%= toggle_group_styles %>">
      <a href="<%= @list_url %>" style="<%= list_button_styles %>"
        title="List view" aria-pressed="<%= list_active? %>">
        <i class="bi bi-list-ul" aria-hidden="true"></i>
      </a>
      <a href="<%= @card_url %>" style="<%= toggle_button_styles(:card) %>"
        title="Card view" aria-pressed="<%= card_active? %>">
        <i class="bi bi-grid-3x2-gap" aria-hidden="true"></i>
      </a>
    </div>
    <% if @sort_options.any? %>
      <select style="<%= sort_select_styles %>" aria-label="Sort by">
        <% @sort_options.each do |option| %>
          <option value="<%= option[1] %>"<% if @sort_by == option[1] %> selected<% end %>><%= option[0] %></option>
        <% end %>
      </select>
    <% end %>
  </div>
</div>
