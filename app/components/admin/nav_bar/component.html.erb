<% if show_env_bar? %>
  <div class="<%= env_bar_class %>"></div>
<% end %>

<nav aria-label="Main navigation">
  <div class="mds-navbar d-flex align-items-center justify-content-between px-3">
    <div class="d-flex align-items-center gap-3">
      <a href="<%= @logo_href %>" class="mds-navbar__brand d-flex align-items-center gap-2">
        <%= markaz_logo_svg %>
        <span><%= @logo_text %></span>
      </a>

      <div class="d-flex align-items-center">
        <% visible_sections.each do |section| %>
          <a href="<%= section[:href] %>"
             class="<%= section_link_class(section[:key]) %>"
             <% if @current_section == section[:key] %>aria-current="page"<% end %>>
            <%= section[:label] %>
          </a>
        <% end %>
      </div>
    </div>

    <div class="d-flex align-items-center gap-3">
      <% if @search_url %>
        <div class="mds-navbar__search">
          <%= render Admin::SearchBar::Component.new(url: @search_url, placeholder: @search_placeholder, size: :md) %>
        </div>
      <% end %>

      <% if @system_url %>
        <a href="<%= @system_url %>" class="mds-navbar__gear" aria-label="System administration">
          <%= gear_svg %>
        </a>
      <% end %>

      <% if show_user_menu? %>
        <div class="dropdown">
          <button class="btn btn-link p-0 border-0" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="User menu">
            <%= render Admin::AvatarCircle::Component.new(name: @user_name, size: :sm, variant: :nav) %>
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <% if @user_name %>
              <li><span class="dropdown-item-text fw-semibold"><%= @user_name %></span></li>
              <li><hr class="dropdown-divider"></li>
            <% end %>
            <% if @profile_url %>
              <li><a class="dropdown-item" href="<%= @profile_url %>">Profile</a></li>
            <% end %>
            <% if @sign_out_url %>
              <li>
                <a class="dropdown-item" href="<%= @sign_out_url %>" data-turbo-method="<%= @sign_out_method %>">
                  Sign out
                </a>
              </li>
            <% end %>
          </ul>
        </div>
      <% else %>
        <%= render Admin::AvatarCircle::Component.new(name: @user_name, size: :sm, variant: :nav) %>
      <% end %>
    </div>
  </div>
</nav>

<% if show_subnav? %>
  <nav aria-label="Section navigation">
    <div class="mds-subnav d-flex align-items-center px-3">
      <% current_subsections.each do |sub| %>
        <a href="<%= sub[:href] %>"
           class="<%= subnav_link_class(sub[:key]) %>"
           <% if @current_subsection == sub[:key] %>aria-current="page"<% end %>>
          <%= sub[:label] %>
        </a>
      <% end %>
    </div>
  </nav>
<% end %>
