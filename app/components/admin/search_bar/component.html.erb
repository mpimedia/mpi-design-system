<%= content_tag(:form, action: @url, method: "get", role: "search", data: form_data) do %>
  <div class="input-group">
    <span class="input-group-text bg-white">
      <i class="bi bi-search" aria-hidden="true"></i>
    </span>
    <input type="search"
           class="<%= input_class %>"
           name="<%= @name %>"
           value="<%= @value %>"
           placeholder="<%= @placeholder %>"
           aria-label="Search"
           autocomplete="off">
    <% if has_value? %>
      <%= link_to clear_url, class: "btn btn-outline-secondary", aria: { label: "Clear search" } do %>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      <% end %>
    <% end %>
    <% if @show_button %>
      <button type="submit" class="btn btn-primary">Search</button>
    <% end %>
  </div>
<% end %>
