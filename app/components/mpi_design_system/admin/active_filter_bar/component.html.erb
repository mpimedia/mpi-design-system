<% if show? %>
  <%# The bar surface is `.bg-body-secondary` тАФ adaptive тАФ so there is no
      `data-bs-theme` pin here. #130 pinned `data-bs-theme="light"` because the
      surface was a frozen light hex ($mpi-background) paired with a theme-aware
      `.text-body-secondary` label (light-on-light, 1.16:1, in dark mode). With an
      adaptive surface the label and bar flip together тАФ `.text-body-secondary` on
      `.bg-body-secondary` stays ~5.76:1 light / 5.77:1 dark тАФ and pinning light would
      now be the regression, blocking dark mode. (#150) %>
  <div class="bg-body-secondary rounded" style="<%= bar_styles %>" role="toolbar" aria-label="Active filters">
    <span class="text-body-secondary" style="<%= label_styles %>">Active:</span>
    <% @filters.each do |filter| %>
      <span class="rounded-pill text-bg-primary" style="<%= pill_styles %>">
        <%= pill_label(filter) %>
        <% if filter[:remove_url] %>
          <a href="<%= filter[:remove_url] %>"
             style="<%= remove_btn_styles %>"
             aria-label="Remove filter: <%= pill_label(filter) %>"
             data-turbo-method="delete">
            <i class="bi bi-x" aria-hidden="true"></i>
          </a>
        <% end %>
      </span>
    <% end %>
    <% if @clear_all_url %>
      <a href="<%= @clear_all_url %>" class="text-body-secondary" style="<%= clear_all_styles %>" aria-label="Clear all filters">Clear all</a>
    <% end %>
  </div>
<% end %>
