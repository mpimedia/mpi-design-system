<div class="d-inline-flex align-items-center" aria-label="<%= stack_label %>" role="group">
  <% visible_names.each_with_index do |name, i| %>
    <div style="<%= "margin-left: -8px;" if i > 0 %> position: relative; z-index: <%= visible_names.length - i %>;">
      <%= render MpiDesignSystem::Admin::AvatarCircle::Component.new(name: name, size: @size) %>
    </div>
  <% end %>
  <% if overflow? %>
    <div style="margin-left: -8px; position: relative; z-index: 0;">
      <%# The separator ring tracks the body background (var(--bs-body-bg)) so it stays
          the surface colour in either colour mode rather than pinning #fff. The chip's
          own background/foreground are the shared avatar overflow custom properties
          (var(--mds-avatar-overflow[-fg], <fallback>)) so they re-brand and adapt to dark
          mode with the palette; the fallback is the #130-derived AA pair. (#169) %>
      <span class="d-inline-flex align-items-center justify-content-center rounded-circle fw-semibold"
            style="width: <%= dimension %>px; height: <%= dimension %>px; font-size: 11px; background-color: <%= overflow_background_color %>; color: <%= overflow_foreground_color %>; border: 2px solid var(--bs-body-bg); line-height: 1;"
            aria-hidden="true">
        +<%= overflow_count %>
      </span>
    </div>
  <% end %>
</div>
