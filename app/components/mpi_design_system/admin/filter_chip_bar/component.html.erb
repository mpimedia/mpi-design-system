<div>
  <% if show_groups? %>
    <div class="d-flex align-items-center flex-wrap gap-2 mb-2" role="group" aria-label="Filter by group">
      <span style="<%= label_styles %>">Groups:</span>
      <% @groups.each do |chip| %>
        <% if chip[:href] %>
          <a href="<%= chip[:href] %>"
             style="<%= group_chip_styles(chip) %>"
             <% if chip[:selected] %>aria-current="page"<% end %>>
            <%= chip_label(chip) %>
          </a>
        <% else %>
          <span style="<%= group_chip_styles(chip) %>">
            <%= chip_label(chip) %>
          </span>
        <% end %>
      <% end %>
      <% if @reset_all_url %>
        <a href="<%= @reset_all_url %>" style="<%= reset_all_styles %>" aria-label="Reset all filters">Reset all</a>
      <% end %>
    </div>
  <% end %>

  <% if show_active_filters? %>
    <div class="d-flex align-items-center flex-wrap gap-2">
      <span style="<%= label_styles %>">Active:</span>
      <% @active_filters.each do |filter| %>
        <span style="<%= active_pill_styles %>">
          <%= pill_label(filter) %>
          <% if filter[:remove_url] %>
            <a href="<%= filter[:remove_url] %>"
               style="<%= remove_btn_styles %>"
               aria-label="Remove filter: <%= pill_label(filter) %>"
               data-turbo-method="delete">
              <i class="bi bi-x" aria-hidden="true"></i>
            </a>
          <% end %>
        </span>
      <% end %>
      <% if @clear_all_url %>
        <a href="<%= @clear_all_url %>" style="<%= clear_all_styles %>" aria-label="Clear all filters">Clear all</a>
      <% end %>
    </div>
  <% end %>
</div>
