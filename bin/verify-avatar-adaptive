#!/usr/bin/env ruby
# frozen_string_literal: true

# Verifies the theme-adaptive avatar partial (#169). `_avatar.scss` emits the
# `--mds-avatar-*` runtime custom properties AvatarCircle / AvatarStack paint via
# `var(--mds-avatar-N, <fallback>)`, in two blocks: a light `:root` and a
# `[data-bs-theme="dark"]` override. This is the compile-level guard that the partial
# actually materialises EVERY role, in BOTH modes, with the right values; the browser
# paint proof lives in spec/features/contrast_spec.rb, and the contrast correctness of
# the foregrounds in bin/verify-contrast-oracle.
#
# It runs against the STANDALONE-compiled fixture (spec/fixtures/scss/
# avatar_adaptive.scss -> tmp/compat/avatar_adaptive.css). That the fixture compiles
# at all — with neither Bootstrap nor app config in scope — proves the partial is
# Bootstrap-free. This script then proves, at per-declaration resolution:
#
#   0. STRONG NEGATIVE — the compiled partial contains ONLY the light group selector
#      (`:root, [data-bs-theme="light"]`, mirroring Bootstrap so a nested light section does
#      not inherit the dark ancestor's tokens) and the `[data-bs-theme="dark"]` override, and
#      every declaration in them is a `--mds-avatar-*` custom property. A stray rule
#      (`.mds-avatar--nav { color: red }`) or a non-token declaration — which could override
#      the component's accessible inline foreground — reds here rather than shipping green.
#   1. COVERAGE — the light group and the dark block EACH declare `--mds-avatar-<role>` and
#      `--mds-avatar-<role>-fg` for every role in `$mpi-avatar-palette` (the source of
#      truth), and nothing extra.
#   2. BINDING — each declared value equals the palette's value for that role AND mode
#      (`bg`/`fg` in the light group, `bg-dark`/`fg-dark` in the dark block). A partial loop
#      bug that emitted the light value in the dark block — the exact "dark is a copy of
#      light" regression — reds here.
#   3. ADAPTIVITY — every role's background actually CHANGES between the two modes, so
#      a dark block that merely re-emitted the light palette cannot pass.
#
# The expected values are parsed from `_tokens_values.scss`, not frozen here, so the
# guard cannot drift from the palette source. Run via `yarn build:css:compat`. Prove it
# by breaking it (per .claude/rules/frontend.md) — each mutation reds a DIFFERENT check,
# and all were confirmed by execution:
#   * add `.mds-avatar--nav { color: red }` to _avatar.scss -> STRONG NEGATIVE (UNEXPECTED RULE)
#   * add a non-token declaration to a mode block -> STRONG NEGATIVE (STRAY DECL)
#   * prepend a SECOND `:root, [data-bs-theme="light"] { color: red }` block -> STRONG NEGATIVE
#     (DUPLICATE BLOCK + STRAY DECL). Declarations are scanned across EVERY block, not a
#     selector-deduped hash, so a duplicate approved selector cannot smuggle a stray declaration.
#   * drop the `[data-bs-theme="dark"]` block from _avatar.scss -> COVERAGE (MISSING BLOCK)
#   * change the dark `@each` to read `bg`/`fg` instead of `bg-dark`/`fg-dark` -> BINDING
#     (WRONG (dark)) on every role. NOT ADAPTIVITY — that check compares the palette's own
#     bg vs bg-dark parsed from the source map, so it is independent of what the partial
#     compiled and stays green under this mutation.
#   * set a role's `bg-dark` equal to its `bg` in the $mpi-avatar-palette source map ->
#     ADAPTIVITY (NOT ADAPTIVE) for that role — this is the mutation that check exists for.
#   * delete a role from the palette map -> the compiled output and the parsed expectation
#     move together (no false green); a role emitted for only one mode reds COVERAGE.

CSS = ARGV[0] || "tmp/compat/avatar_adaptive.css"
ROOT = File.expand_path("..", __dir__)
TOKENS = File.join(ROOT, "app/assets/stylesheets/mpi_design_system/_tokens_values.scss")

unless File.file?(CSS)
  warn "verify-avatar-adaptive: #{CSS} not found — compile the fixture first"
  exit 1
end

# --- Parse the palette source of truth from _tokens_values.scss. Each role line is
#     `<role>: (bg: #hex, fg: #hex, bg-dark: #hex, fg-dark: #hex),` inside the
#     `$mpi-avatar-palette:` map.
source = File.read(TOKENS)
map_body = source[/\$mpi-avatar-palette:\s*\((.*?)\)\s*!default;/m, 1]
abort "verify-avatar-adaptive: could not find $mpi-avatar-palette in _tokens_values.scss" if map_body.nil?

palette = {}
map_body.scan(/(\w+):\s*\(\s*bg:\s*(#\h+),\s*fg:\s*(#\h+),\s*bg-dark:\s*(#\h+),\s*fg-dark:\s*(#\h+)\s*\)/) do
  role, bg, fg, bg_dark, fg_dark = Regexp.last_match.captures
  palette[role] = { bg: bg, fg: fg, bg_dark: bg_dark, fg_dark: fg_dark }
end
abort "verify-avatar-adaptive: parsed 0 roles from the palette — the map format changed" if palette.empty?

# --- Parse the compiled CSS into every rule block: normalised-selector => {prop => value}.
#     Sass drops the quotes around the attribute value and may or may not space the group
#     comma, so normalise whitespace for matching. The partial emits the light palette on a
#     GROUPED selector (`:root, [data-bs-theme="light"]`) mirroring Bootstrap, and the dark
#     override on `[data-bs-theme="dark"]`.
css = File.read(CSS)
LIGHT_SELECTOR = ":root, [data-bs-theme=light]"
DARK_SELECTOR = "[data-bs-theme=dark]"

rule_blocks = css.scan(/([^{}]+)\{([^}]*)\}/m).map do |selector, body|
  normalised = selector.strip.gsub(/\s*,\s*/, ", ").gsub(/\s+/, " ")
  declarations = body.split(";").map(&:strip).reject(&:empty?).each_with_object({}) do |decl, acc|
    property, value = decl.split(":", 2)
    acc[property.to_s.strip] = value.to_s.strip
  end
  [ normalised, declarations ]
end

failures = []
allowed = [ LIGHT_SELECTOR, DARK_SELECTOR ]

# 0a. STRONG NEGATIVE (selectors) — the compiled partial must contain ONLY the two approved
#     mode blocks, each EXACTLY ONCE. A stray rule (`.mds-avatar--nav { color: red !important }`)
#     reds; so does a DUPLICATE approved selector, which would otherwise smuggle extra
#     declarations past the per-block scan below — a second `:root, [data-bs-theme=light]`
#     block carrying `color: red` must not hide behind the legitimate one.
selector_counts = Hash.new(0)
rule_blocks.each { |selector, _declarations| selector_counts[selector] += 1 }

rule_blocks.map(&:first).uniq.each do |selector|
  next if allowed.include?(selector)

  failures << "UNEXPECTED RULE   `#{selector}` — the partial may emit only `#{LIGHT_SELECTOR}` and `#{DARK_SELECTOR}`"
end
allowed.each do |selector|
  count = selector_counts[selector]
  failures << "MISSING BLOCK     #{selector} — the partial did not emit this mode" if count.zero?
  failures << "DUPLICATE BLOCK   #{selector} — emitted #{count} times; each approved selector must appear exactly once" if count > 1
end

# 0b. STRONG NEGATIVE (declarations) — scan EVERY block in the compiled output (not a
#     selector-deduped hash), so a duplicate block's stray declarations cannot be discarded
#     before this check. Every declaration in an approved block must be a `--mds-avatar-*`
#     custom property; matches bin/verify-nav-bar-adaptive's per-property strong negative.
rule_blocks.each do |selector, declarations|
  next unless allowed.include?(selector)

  declarations.each_key do |property|
    next if property.start_with?("--mds-avatar-")

    failures << "STRAY DECL        `#{selector} { #{property} }` — only --mds-avatar-* custom properties are allowed"
  end
end

unless failures.empty?
  warn "Avatar adaptive check FAILED:"
  failures.each { |f| warn "  #{f}" }
  exit 1
end

# Value checks below read the approved blocks, now proven unique and token-only above.
blocks = rule_blocks.to_h
light = blocks.fetch(LIGHT_SELECTOR)
dark = blocks.fetch(DARK_SELECTOR)

def eq_hex?(one, other)
  one.to_s.downcase == other.to_s.downcase
end

expected_props = []

palette.each do |role, colours|
  bg_prop = "--mds-avatar-#{role}"
  fg_prop = "--mds-avatar-#{role}-fg"
  expected_props << bg_prop << fg_prop

  # 1/2. COVERAGE + BINDING, light
  if !light.key?(bg_prop)
    failures << "MISSING (light)   #{bg_prop} — role absent from the light block"
  elsif !eq_hex?(light[bg_prop], colours[:bg])
    failures << "WRONG (light)     #{bg_prop}: #{light[bg_prop]} — expected #{colours[:bg]}"
  end
  if !light.key?(fg_prop)
    failures << "MISSING (light)   #{fg_prop} — role absent from the light block"
  elsif !eq_hex?(light[fg_prop], colours[:fg])
    failures << "WRONG (light)     #{fg_prop}: #{light[fg_prop]} — expected #{colours[:fg]}"
  end

  # 1/2. COVERAGE + BINDING, dark
  if !dark.key?(bg_prop)
    failures << "MISSING (dark)    #{bg_prop} — role absent from [data-bs-theme=dark]"
  elsif !eq_hex?(dark[bg_prop], colours[:bg_dark])
    failures << "WRONG (dark)      #{bg_prop}: #{dark[bg_prop]} — expected #{colours[:bg_dark]}"
  end
  if !dark.key?(fg_prop)
    failures << "MISSING (dark)    #{fg_prop} — role absent from [data-bs-theme=dark]"
  elsif !eq_hex?(dark[fg_prop], colours[:fg_dark])
    failures << "WRONG (dark)      #{fg_prop}: #{dark[fg_prop]} — expected #{colours[:fg_dark]}"
  end

  # 3. ADAPTIVITY — the background must actually change between modes, or the dark
  #    block is a copy of light and nothing adapts.
  if eq_hex?(colours[:bg], colours[:bg_dark])
    failures << "NOT ADAPTIVE      #{bg_prop} — light and dark backgrounds are identical (#{colours[:bg]})"
  end
end

# 1. COVERAGE — no stray --mds-avatar-* beyond the palette roles.
[ [ LIGHT_SELECTOR, light ], [ DARK_SELECTOR, dark ] ].each do |name, block|
  block.each_key do |property|
    next unless property.start_with?("--mds-avatar-")
    next if expected_props.include?(property)

    failures << "UNEXPECTED PROP   #{name} { #{property} } — not a palette role/foreground"
  end
end

if failures.any?
  warn ""
  warn "Avatar adaptive check FAILED with #{failures.length} problem(s):"
  failures.each { |failure| warn "  #{failure}" }
  warn ""
  warn "_avatar.scss must emit ONLY `#{LIGHT_SELECTOR}` (bg/fg) and `#{DARK_SELECTOR}` (bg-dark/fg-dark),"
  warn "carrying --mds-avatar-<role>(+ -fg) for every $mpi-avatar-palette role and nothing else, and each"
  warn "role's background must differ between the two modes."
  exit 1
end

puts "Avatar adaptive OK: _avatar.scss compiles standalone into ONLY `#{LIGHT_SELECTOR}` and " \
     "`#{DARK_SELECTOR}` (no stray rules or declarations), materialises all #{palette.size} roles in both " \
     "with their exact palette values, and every background adapts between modes"
