<%= render Admin::AppShell::Component.new(
  current_section: current_section,
  current_subsection: current_subsection,
  user_name: user_name,
  search_url: search_url,
  show_sidebar: show_sidebar
) do |shell| %>
  <% shell.with_sidebar do %>
    <div class="p-3">
      <h6 class="text-uppercase text-muted mb-3" style="font-size: 11px; letter-spacing: 0.5px;">Quick Filters</h6>
      <ul class="list-unstyled">
        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #1B2A4A;">All Contacts</a></li>
        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #1B2A4A;">My Contacts</a></li>
        <li class="mb-2"><a href="#" class="text-decoration-none" style="color: #1B2A4A;">Recently Viewed</a></li>
      </ul>
    </div>
  <% end %>
  <% shell.with_body do %>
    <div class="p-4">
      <h1 class="h3 mb-3" style="color: #1B2A4A;">CRM Contacts</h1>
      <p class="text-muted">Main content area with sidebar visible.</p>
    </div>
  <% end %>
<% end %>
