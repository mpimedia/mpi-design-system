<%= render Admin::EngagementDetailView::Component.new(
  engagement_type: :meeting,
  title: "Quarterly review with Berlin Film Fest",
  date: "Feb 24, 2026 · 2:00 PM CT",
  status: "Completed"
) do |view| %>
  <% view.with_breadcrumb do %>
    <%= render Admin::BreadcrumbNav::Component.new(
      back_path: "#",
      back_label: "Engagements",
      current_title: "Meeting: Quarterly review"
    ) %>
  <% end %>
  <% view.with_tabs do %>
    <%= render Admin::TabBar::Component.new(
      tabs: [
        { label: "Content", active: true, href: "#" },
        { label: "Activity Log", href: "#" }
      ]
    ) %>
  <% end %>
  <% view.with_main_content do %>
    <div style="font-size: 14px; color: #1B2A4A; line-height: 1.6;">
      <p><strong>Attendees:</strong> Robert Fox, Emily Chen, David Kim</p>
      <p><strong>Location:</strong> Zoom</p>
      <p><strong>Notes:</strong></p>
      <ul>
        <li>Reviewed Q1 performance for Berlin Film Festival screenings</li>
        <li>Discussed expanding Asia-Pacific distribution rights</li>
        <li>Next steps: Schedule follow-up with legal team</li>
      </ul>
    </div>
  <% end %>
  <% view.with_sidebar do %>
    <h6 class="text-uppercase" style="font-size: 11px; letter-spacing: 0.06em; color: #6C757D; margin-bottom: 12px;">Linked Contacts</h6>
    <div class="d-flex flex-column gap-2 mb-3">
      <div class="d-flex align-items-center gap-2">
        <%= render Admin::AvatarCircle::Component.new(name: "Robert Fox", size: :sm) %>
        <span style="font-size: 13px; color: #1B2A4A;">Robert Fox</span>
      </div>
      <div class="d-flex align-items-center gap-2">
        <%= render Admin::AvatarCircle::Component.new(name: "Emily Chen", size: :sm) %>
        <span style="font-size: 13px; color: #1B2A4A;">Emily Chen</span>
      </div>
    </div>
  <% end %>
<% end %>
