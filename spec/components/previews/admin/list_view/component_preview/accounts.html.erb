<%= render Admin::ListView::Component.new(
  entity_type: :accounts,
  groups: [
    { label: "All", count: 84, group: nil, selected: true },
    { label: "Distributors", count: 32, group: :vendors, selected: false },
    { label: "Studios", count: 28, group: :production, selected: false },
    { label: "Press/Festival", count: 24, group: :press_festival, selected: false }
