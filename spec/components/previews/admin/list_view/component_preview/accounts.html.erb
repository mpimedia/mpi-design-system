        {
          name: "Berlin Film Festival",
          contacts: "3 contacts",
          tag_groups: [{ group: :press_festival, label: "Press/Festival" }],
          health: "Warm",
          last_engaged: "1 week ago",
          linked_titles: "5 titles"
        },
        {
          name: "Global Distribution Co.",
          contacts: "12 contacts",
          tag_groups: [{ group: :vendors, label: "Vendors" }, { group: :production, label: "Organizations" }],
          health: "Active",
          last_engaged: "Yesterday",
          linked_titles: "34 titles"
        }
      ],
      sort_by: :name,
      sort_dir: :asc
    ) %>
  <% end %>
<% end %>
