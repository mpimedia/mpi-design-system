<%= render Admin::ListView::Component.new(
  entity_type: :contacts,
  groups: [
    { label: "All", count: 156, group: nil, selected: true },
    { label: "Distribution", count: 42, group: :distribution, selected: false },
    { label: "Outreach", count: 28, group: :outreach, selected: false },
    { label: "Press/Festival", count: 35, group: :press_festival, selected: false }
  ],
  total_count: 156,
  current_page: 1,
  per_page: 25,
  sort_by: "name_asc",
  view_mode: :list,
  list_url: "#list",
  card_url: "#card"
) do |view| %>
  <% view.with_table_content do %>
    <%= render Admin::DataTable::Component.new(
      columns: [
        { key: :name, label: "Name", sortable: true },
        { key: :account, label: "Account", sortable: true },
        { key: :tags, label: "Tags" },
        { key: :last_engagement, label: "Last Engagement", sortable: true }
      ],
      rows: [
        { name: "Jane Cooper", account: "Acme Films", tags: [{ group: :distribution, label: "Acquisitions" }], last_engagement: "2 days ago" },
        { name: "Robert Fox", account: "Berlin Film Fest", tags: [{ group: :press_festival, label: "Festival" }], last_engagement: "1 week ago" },
        { name: "Emily Chen", account: "Film Weekly", tags: [{ group: :outreach, label: "Journalist" }, { group: :distribution, label: "Streaming" }], last_engagement: "3 days ago" }
      ],
      sort_by: :name,
      sort_dir: :asc
    ) %>
  <% end %>
<% end %>
