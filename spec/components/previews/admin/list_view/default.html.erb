<%= render Admin::ListView::Component.new(
  entity_type: :contacts,
  groups: [
    { label: "All", count: 156, group: nil, selected: true },
    { label: "Buyers", count: 42, group: :buyers, selected: false },
    { label: "Press", count: 28, group: :press, selected: false },
    { label: "Festivals", count: 35, group: :festivals, selected: false }
  ],
  total_count: 156,
  current_page: 1,
  per_page: 25,
  sort_by: "name_asc",
  view_mode: :list,
  list_url: "#list",
  card_url: "#card"
) do |view| %>
  <% view.with_table_content do %>
    <%= render Admin::DataTable::Component.new(
      columns: [
        { key: :name, label: "Name", sortable: true },
        { key: :title, label: "Title", sortable: true },
        { key: :tags, label: "Tags" },
        { key: :last_engagement, label: "Last Engagement", sortable: true }
      ],
      rows: [
        { name: "Jane Cooper", title: "VP of Acquisitions", tags: [{ group: :buyers, role: "Lead" }], last_engagement: "2 days ago" },
        { name: "Robert Fox", title: "Festival Director", tags: [{ group: :festivals, role: "Director" }], last_engagement: "1 week ago" },
        { name: "Emily Chen", title: "Press Manager", tags: [{ group: :press, role: "Contact" }], last_engagement: "3 days ago" }
      ],
      sort_by: :name,
      sort_dir: :asc
    ) %>
  <% end %>
<% end %>
